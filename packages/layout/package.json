{
  "name": "@bromaid/layout",
  "version": "0.1.1",
  "description": "ELK-based layout for @bromaid. Server- and edge-runtime safe (no worker).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaarvik/bromaid.git",
    "directory": "packages/layout"
  },
  "homepage": "https://github.com/vaarvik/bromaid#readme",
  "bugs": {
    "url": "https://github.com/vaarvik/bromaid/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bromaid/core": "workspace:*"
  },
  "peerDependencies": {
    "elkjs": "^0.9.3"
  },
  "devDependencies": {
    "elkjs": "^0.9.3",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
