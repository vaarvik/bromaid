{
  "name": "@bromaid/renderer",
  "version": "0.1.1",
  "description": "Pure-string SVG renderer for @bromaid LayoutGraph. DOM-free, RSC-safe.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaarvik/bromaid.git",
    "directory": "packages/renderer"
  },
  "homepage": "https://github.com/vaarvik/bromaid#readme",
  "bugs": {
    "url": "https://github.com/vaarvik/bromaid/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bromaid/core": "workspace:*",
    "@bromaid/layout": "workspace:*",
    "@bromaid/theme": "workspace:*"
  },
  "devDependencies": {
    "elkjs": "^0.9.3",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
